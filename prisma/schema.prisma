// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Menggunakan postgresql, bukan mysql
  
 
}

model LaporanBencana {
  id             Int      @id @default(autoincrement())
  namaPelapor    String   @db.VarChar(255)
  noTelepon      String   @db.VarChar(20)
  jenisKelamin   String   @db.VarChar(50)
  provinsi       String   @db.VarChar(100)
  kabupaten      String   @db.VarChar(100)
  kecamatan      String   @db.VarChar(100)
  alamatLengkap  String   @db.Text
  jenisBencana   String   @db.VarChar(100)
  tingkatDarurat String   @db.VarChar(50)
  jumlahKorban   Int      @default(0)
  deskripsi      String   @db.Text
  status         String   @default("Menunggu") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("laporan_bencana")
  @@index([provinsi])
  @@index([jenisBencana])
  @@index([status])
  @@index([createdAt])
}

model StatistikBencana {
  id             Int      @id @default(autoincrement())
  tahun          Int
  jenisBencana   String   @db.VarChar(100)
  jumlahKejadian Int
  jumlahKorban   Int
  jumlahDampak   Int
  provinsi       String   @db.VarChar(100)
  createdAt      DateTime @default(now())

  @@map("statistik_bencana")
  @@index([tahun])
  @@index([provinsi])
  @@index([jenisBencana])
}

model Komentar {
  id         Int      @id @default(autoincrement())
  topikId    String   @db.VarChar(50)
  topikJenis String   @db.VarChar(50)
  nama       String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  isi        String   @db.Text
  disetujui  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("komentar")
  @@index([topikId, topikJenis])
  @@index([disetujui])
}

model CuacaPeringatan {
  id            Int      @id @default(autoincrement())
  provinsi      String   @db.VarChar(100)
  jenis         String   @db.VarChar(100)
  level         String   @db.VarChar(50)
  pesan         String   @db.Text
  berlakuHingga DateTime
  aktif         Boolean  @default(true)
  createdAt     DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}