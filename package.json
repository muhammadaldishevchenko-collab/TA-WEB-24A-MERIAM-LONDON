{
  "name": "bencana-app",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev":         "next dev",
    "build":       "next build",
    "start":       "next start",
    "lint":        "next lint",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate dev --name init",
    "db:seed":     "prisma db seed",
    "db:studio":   "prisma studio",
    "db:generate": "prisma generate",
    "db:reset":    "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dotenv":         "^16.0.0",
    "lucide-react":   "latest",
    "pg":             "^8.11.0",
    "next":           "15.0.0",
    "react":          "^19.0.0",
    "react-dom":      "^19.0.0"
  },
  "devDependencies": {
    "@types/node":      "^22.0.0",
    "@types/pg":        "^8.11.0",
    "@types/react":     "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma":           "6.19.3",
    "ts-node":          "^10.9.2",
    "typescript":       "^5.9.3"
  }
}